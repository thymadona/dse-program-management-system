# Copy to apps/frontend/.env.local and fill in.

NEXT_PUBLIC_API_URL=http://localhost:4000

# Which auth scheme the frontend uses. `dev` = static dev token below;
# `supabase` = real login page + session token. Defaults to dev.
NEXT_PUBLIC_AUTH_MODE=dev

# dev mode only: paste a token from `bun run gen-token --role admin`.
NEXT_PUBLIC_DEV_TOKEN=

# supabase mode only: project URL + public anon key (safe to expose).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

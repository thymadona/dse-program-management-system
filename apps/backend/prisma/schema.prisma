generator client {
  provider      = "prisma-client-js"
  // Debian 12 (oven/bun image) ships OpenSSL 3.0; pin the engine so Prisma
  // doesn't misdetect and fall back to the incompatible 1.1.x binary.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StudentStatus {
  Active
  Inactive
  Pending
}

enum Role {
  admin
  lecturer
  student
}

enum OfferingStatus {
  Planned
  Active
  Completed
}

/// Syllabus §12 "Course Availability" — which semester the course is delivered in.
enum Semester {
  First
  Second
}

/// Syllabus §11 "Course Type".
enum CourseType {
  Basic
  Core
  Elective
  Specialization
  MoeysHeip
}

/// Minimal user table for local dev auth. Replaced/augmented by Supabase Auth later.
/// Lecturers are Users with role = lecturer, surfaced via the Lecturers plugin.
/// title/qualification/phone feed the syllabus "Course Details" instructor block.
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  role          Role     @default(student)
  title         String?
  qualification String?
  phone         String?
  createdAt     DateTime @default(now())

  coursesLed   Course[]   @relation("CourseLecturer")
  offeringsLed Offering[] @relation("OfferingLecturer")
}

/// Students plugin domain model.
model Student {
  id        String        @id @default(uuid())
  name      String
  email     String        @unique
  studentId String        @unique
  status    StudentStatus @default(Active)
  createdAt DateTime      @default(now())

  enrollments Enrollment[]

  @@index([status])
}

/// Courses plugin domain model. lecturerId references a User with role = lecturer
/// (validated at the service layer through registry.get('lecturers')).
model Course {
  id          String   @id @default(uuid())
  code        String   @unique
  title       String
  description String?
  lecturerId  String?
  lecturer    User?    @relation("CourseLecturer", fields: [lecturerId], references: [id], onDelete: SetNull)
  // Syllabus Course Information — §4 credits, §5 prerequisites (free text), §11 type.
  credits       Int?
  prerequisites String?
  courseType    CourseType?
  createdAt   DateTime @default(now())

  offerings Offering[]
  spec      CourseSpec?
}

/// Course Specification wizard — the full RUPP syllabus (Part 2 §1–25) captured as a
/// single JSON document per course. `data` holds each section's content keyed by
/// section id; `status` tracks per-section draft/complete so a lecturer can save one
/// section and continue later. Overlapping §1–13 scalars are mirrored onto Course.
model CourseSpec {
  id        String   @id @default(uuid())
  courseId  String   @unique
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  data      Json     @default("{}")
  status    Json     @default("{}")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

/// Course Offerings plugin — a course delivered in a given term, with an assigned
/// lecturer, a seat capacity, and enrolled students. The architectural proof point:
/// it links Students <-> Courses <-> Lecturers through the registry.
model Offering {
  id         String         @id @default(uuid())
  courseId   String
  course     Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lecturerId String?
  lecturer   User?          @relation("OfferingLecturer", fields: [lecturerId], references: [id], onDelete: SetNull)
  term       String
  capacity   Int            @default(30)
  status     OfferingStatus @default(Planned)
  // Syllabus §12 Course Availability — optional, filled on the course spec form.
  semester      Semester?
  programmeYear Int?
  // Syllabus §10 Other Course Lecturer(s) — optional free text, varies per term.
  otherLecturers String?
  createdAt  DateTime       @default(now())

  enrollments Enrollment[]

  @@unique([courseId, term])
  @@index([status])
}

/// Join model linking a Student to an Offering (enrollment).
model Enrollment {
  id         String   @id @default(uuid())
  offeringId String
  offering   Offering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([offeringId, studentId])
}

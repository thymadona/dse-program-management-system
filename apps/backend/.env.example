# Copy to apps/backend/.env and fill in.

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/dsepms?schema=public"

# --- Server ---
PORT=4000
CORS_ORIGIN=http://localhost:3000

# --- Auth ---
# Which auth scheme the backend verifies. `dev` = local HS256 dev tokens
# (bun run gen-token); `supabase` = real Supabase Auth. Defaults to dev.
AUTH_MODE=dev

# dev mode only: secret used to sign/verify local dev tokens.
JWT_SECRET=change-me-to-a-long-random-string

# supabase mode only ------------------------------------------------------------
# JWKS endpoint for the project (asymmetric signing). Verifies incoming tokens.
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# Admin API base + service_role key (SERVER-ONLY secret) for inviting accounts.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# Where invite/set-password links land (your frontend callback route).
SUPABASE_INVITE_REDIRECT_URL=http://localhost:3000/auth/callback

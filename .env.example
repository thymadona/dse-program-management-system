# ── Backend ────────────────────────────────────────────────────────────────
# Local Postgres from docker-compose.yml
DATABASE_URL="postgresql://dsepms:dsepms@localhost:5432/dsepms?schema=public"

# Local HS256 signing secret for dev JWTs. Swapped for Supabase JWT verification later.
JWT_SECRET="dev-only-change-me-super-secret"

# Backend HTTP port
PORT=4000

# Comma-separated allowed origins for CORS
CORS_ORIGIN="http://localhost:3000"

# ── Frontend ───────────────────────────────────────────────────────────────
# Base URL of the backend API
NEXT_PUBLIC_API_URL="http://localhost:4000"

# TEMPORARY: dev bearer token minted by `bun run gen-token`. Replaced by real
# login (Supabase) later. Paste the output of gen-token here.
NEXT_PUBLIC_DEV_TOKEN=""
